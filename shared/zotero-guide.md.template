    VALUES (3, 1, ?, 0, 0, datetime('now'), datetime('now'), datetime('now'))
""", (att_key,))
att_id = cur.execute("SELECT last_insert_rowid()").fetchone()[0]

cur.execute("""
    INSERT INTO itemAttachments (itemID, parentItemID, linkMode, contentType, path, charsetID)
    VALUES (?, ?, 0, 'application/pdf', ?, NULL)
""", (att_id, parent_item_id, "storage:" + filename))

# PDF 物理文件放到 ~/Zotero/storage/{att_key}/filename
```

